{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sphinx Build: html",
            "type": "shell",
            "command": "poetry run make.bat html",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "View in browser: index.html",
            "type": "shell",
            "command": "${workspaceFolder}/build/html/index.html",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": [
                "Sphinx Build: html"
            ]
        }
    ]
}